generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum ConversationStatus {
  NEW
  IN_PROGRESS
  WAITING
  FINISHED
}

enum MessageDirection {
  IN
  OUT
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  LINK
}

enum UserRole {
  ADMIN
  AGENT
}

// ─────────────────────────────────────────
// WhatsApp Integration (dynamic credentials)
// ─────────────────────────────────────────

model Integration {
  id            String    @id @default(uuid())
  provider      String    @default("EVOLUTION")
  base_url      String
  api_key       String
  instance_name String    @unique
  status        String    @default("DISCONNECTED")
  connected_at  DateTime?
  updated_at    DateTime  @updatedAt

  @@map("integrations")
}

// ─────────────────────────────────────────
// CRM
// ─────────────────────────────────────────

model Contact {
  id            String         @id @default(uuid())
  phone         String         @unique
  name          String?
  tags          String[]       @default([])
  created_at    DateTime       @default(now())
  last_seen     DateTime       @default(now())
  conversations Conversation[]

  @@map("contacts")
}

model Conversation {
  id          String             @id @default(uuid())
  contact_id  String
  contact     Contact            @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  status      ConversationStatus @default(NEW)
  assigned_to String?
  tags        String[]           @default([])
  notes       String?
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt
  messages    Message[]

  @@map("conversations")
}

model Message {
  id              String           @id @default(uuid())
  conversation_id String
  conversation    Conversation     @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  direction       MessageDirection
  type            MessageType      @default(TEXT)
  content         String
  media_url       String?
  timestamp       DateTime         @default(now())

  @@map("messages")
}

// ─────────────────────────────────────────
// Templates & Automations
// ─────────────────────────────────────────

model Template {
  id        String   @id @default(uuid())
  name      String   @unique
  content   String
  variables String[] @default([])
  created_at DateTime @default(now())

  @@map("templates")
}

model Automation {
  id        String   @id @default(uuid())
  // Types: WELCOME | SCHEDULE | OFFER | KEYWORD
  type      String
  trigger   String?
  content   String?
  media_url String?
  enabled   Boolean  @default(true)
  schedule  Json?

  @@map("automations")
}

// ─────────────────────────────────────────
// Users / Agents
// ─────────────────────────────────────────

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  role       UserRole @default(AGENT)
  created_at DateTime @default(now())

  @@map("users")
}

// ─────────────────────────────────────────
// Store Settings (singleton row id="store_config")
// ─────────────────────────────────────────

model Settings {
  id              String  @id @default("store_config")
  store_name      String
  logo_url        String?
  // JSON: { "monday": { "start": "08:00", "end": "18:00", "closed": false }, ... }
  open_hours      Json
  offer_image_url String?
  // JSON: { "catalog": "...", "menu": "...", "app": "..." }
  app_links       Json

  @@map("settings")
}
